{% extends '_layouts/base.twig' %}

{% block body %}
    <main class="mx-auto min-h-screen max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <header class="mb-8 text-center">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Fast, Fresh & Delicious</p>
            <h1 class="mt-2 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">One Dream</h1>
            <p class="mt-3 text-sm text-slate-500">Contact Us</p>
        </header>

        <section class="mx-auto mb-6 max-w-5xl rounded-lg bg-white p-8 shadow-sm ring-1 ring-slate-200">
            {% if entry.formattedText %}
                <div class="prose prose-a:text-blue-600 prose-a:hover:text-blue-800">
                    {{ entry.formattedText }}
                </div>
            {% endif %}

            <div class="mt-12 space-y-4 text-sm leading-6 text-slate-950 font-semibold">
                <div class="flex items-start gap-3">
                    <svg class="mt-0.5 size-5 shrink-0 text-slate-500" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 21s7-5.1 7-12A7 7 0 0 0 5 9c0 6.9 7 12 7 12Z" />
                        <circle cx="12" cy="9" r="2.5" />
                    </svg>
                    <p>
                        616 Columbia Street Ext.<br>
                        Latham, NY, United States, New York
                    </p>
                </div>

                <div class="flex items-start gap-3">
                    <svg class="mt-0.5 size-5 shrink-0 text-slate-500" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z" />
                    </svg>
                    <a class="font-semibold text-blue-600 hover:text-blue-800 hover:underline" href="tel:+15182505545">(518) 250-5545</a>
                </div>

                <div class="flex items-start gap-3">
                    <svg class="mt-0.5 size-5 shrink-0 text-slate-500" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect width="20" height="16" x="2" y="4" rx="2" />
                        <path d="m22 7-10 6L2 7" />
                    </svg>
                    <a class="font-semibold text-blue-600 hover:text-blue-800 hover:underline" href="mailto:gtbfuel9corp@gmail.com">gtbfuel9corp@gmail.com</a>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
