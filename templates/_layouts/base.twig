<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8" />
    <title>{% block title %}One Dream Coming Soon{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="origin-when-cross-origin" />
    <link rel="stylesheet" href="/app.css" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak] { display: none !important; }</style>
</head>
<body class="min-h-screen {% block bodyClass %}bg-stone-100 text-stone-900{% endblock %}">
    <nav class="px-6 py-5" x-data="{ open: false }">
        <div class="mx-auto flex max-w-7xl items-center justify-between">
            <a href="/" class="text-lg font-semibold tracking-tight">One Dream</a>

            <div class="hidden items-center gap-8 text-sm font-medium text-stone-600 md:flex">
                <a href="/menu" class="hover:text-stone-950">Menu</a>
                <a href="/about" class="hover:text-stone-950">About</a>
                <a href="/contact" class="hover:text-stone-950">Contact</a>
            </div>

            <button
                class="inline-flex size-10 items-center justify-center rounded-md ring-1 ring-stone-300 md:hidden"
                type="button"
                aria-label="Toggle navigation"
                :aria-expanded="open"
                @click="open = !open"
            >
                <span class="sr-only">Toggle navigation</span>
                <span class="flex w-5 flex-col gap-1.5">
                    <span class="h-0.5 rounded-full bg-stone-900"></span>
                    <span class="h-0.5 rounded-full bg-stone-900"></span>
                    <span class="h-0.5 rounded-full bg-stone-900"></span>
                </span>
            </button>
        </div>

        <div class="mx-auto mt-4 max-w-5xl rounded-lg bg-white p-4 shadow-sm ring-1 ring-stone-200 md:hidden" x-cloak x-show="open" @click.outside="open = false">
            <div class="flex flex-col gap-3 text-sm font-medium text-stone-600">
                <a href="/menu" class="hover:text-stone-950">Menu</a>
                <a href="/about" class="hover:text-stone-950">About</a>
                <a href="/contact" class="hover:text-stone-950">Contact</a>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}
</body>
</html>
